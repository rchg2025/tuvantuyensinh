generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Question {
  id           String    @id @default(cuid())
  askerName    String
  phone        String?
  email        String?
  question     String
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  isFromSchool Boolean   @default(false)
  answer       String?
  answeredBy   String?
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Post {
  id           String    @id @default(cuid())
  slug         String?   @unique
  title        String
  content      String
  thumbnailUrl String?
  attachments  String?   // JSON str or single URL
  viewCount    Int       @default(0)
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  authorName   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ConsultationRequest {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  program     String?
  notes       String?
  isProcessed Boolean  @default(false)
  status      String   @default("Cần tư vấn")
  history     String?  @db.Text
  createdAt   DateTime @default(now())
}

enum CategoryType {
  MAJOR
  POSITION
  POST
}

model Category {
  id          String       @id @default(cuid())
  slug        String?      @unique
  name        String       @unique
  description String?
  type        CategoryType @default(MAJOR)
  posts       Post[]
  users       SystemUser[]
  questions   Question[]
  createdAt   DateTime     @default(now())
}

model SystemUser {
  id         String    @id @default(cuid())
  email      String    @unique
  phone      String?
  password   String
  name       String?
  role       String    @default("ADMIN")
  positionId String?
  position   Category? @relation(fields: [positionId], references: [id])
  otp        String?
  otpExpiry  DateTime?
  createdAt  DateTime  @default(now())
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
