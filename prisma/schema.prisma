generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Question {
  id           String    @id @default(cuid())
  askerName    String
  phone        String?
  email        String?
  question     String
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  isFromSchool Boolean   @default(false)
  answer       String?
  answeredBy   String?
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([createdAt])
  @@index([categoryId])
  @@index([isFromSchool])
}

model Post {
  id           String    @id @default(cuid())
  slug         String?   @unique
  title        String
  content      String
  thumbnailUrl String?
  attachments  String? // JSON str or single URL
  gallery      String? @db.Text // JSON string of array of URLs
  galleryConfig String? // JSON string of gallery configuration
  viewCount    Int       @default(0)
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  comments     Comment[]
  authorName   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([createdAt])
  @@index([categoryId])
}

model Comment {
  id         String    @id @default(cuid())
  postId     String
  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  email      String
  content    String
  
  // Dành cho Admin phản hồi
  adminReply String?
  repliedAt  DateTime?
  repliedBy  String?
  
  isApproved Boolean   @default(false) // Cần admin duyệt
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([postId])
  @@index([createdAt])
}

model ConsultationRequest {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  program     String?
  notes       String?
  isProcessed Boolean  @default(false)
  status      String   @default("Cần tư vấn")
  history     String?  @db.Text
  createdAt   DateTime @default(now())
}

enum CategoryType {
  MAJOR
  POSITION
  POST
}

model Category {
  id          String       @id @default(cuid())
  slug        String?      @unique
  name        String       @unique
  description String?
  type        CategoryType @default(MAJOR)
  posts       Post[]
  users       SystemUser[]
  questions   Question[]
  createdAt   DateTime     @default(now())
}

model SystemUser {
  id         String    @id @default(cuid())
  email      String    @unique
  phone      String?
  password   String
  name       String?
  avatar     String?
  role       String    @default("ADMIN")
  positionId String?
  position   Category? @relation(fields: [positionId], references: [id])
  otp        String?
  otpExpiry  DateTime?
  createdAt  DateTime  @default(now())
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model VisitorStat {
  date      String   @id // YYYY-MM-DD
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActiveSession {
  id        String   @id
  updatedAt DateTime @updatedAt
}
